{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,//needed for @Entity @Column with typeorm.
    "emitDecoratorMetadata": true,//needed for @Entity @Column with typeorm.
  },
  "include": ["src/**/*"],
}